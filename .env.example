# Example environment file. Copy to .env and fill in real values.
# The .env file is gitignored and holds the real secrets.
#
# Comments are on their own lines on purpose. Inline comments after a value are
# not handled consistently by every consumer of this file (docker compose and
# python-dotenv differ on empty values), so keep each comment on its own line.

# --- Postgres container (used by docker-compose to provision the database) ---
# Database role created in the postgres service.
POSTGRES_USER=ehss
# Password for that role. Change it for any shared host.
POSTGRES_PASSWORD=ehss
# Database name created on first start.
POSTGRES_DB=ehss
# Service hostname on the Docker network. Use localhost from the host machine.
POSTGRES_HOST=postgres
# Postgres port.
POSTGRES_PORT=5432

# --- Application database connection (read by config/settings.py) ---
# Must point at the same Postgres as above. Inside Docker the host is "postgres";
# from the host machine (running pytest or dbt directly) use "localhost".
DATABASE_URL=postgresql+psycopg2://ehss:ehss@postgres:5432/ehss

# --- dbt ---
# Default schema dbt writes marts into.
DBT_SCHEMA=marts

# --- OSHA data source ---
# Confirm the current Case Detail download link on the ITA Data page first:
# https://www.osha.gov/Establishment-Specific-Injury-and-Illness-Data
OSHA_DATA_URL=https://www.osha.gov/sites/default/files/ITA-data/ITA-data-case-detail-cy2024.zip

# --- Sampling ---
# Number of narrated rows kept for the demo.
SAMPLE_SIZE=1000
# Fixed seed so sampling is reproducible.
SAMPLE_RANDOM_SEED=42

# --- LLM enrichment (local Ollama, OpenAI-compatible API) ---
# Install Ollama from ollama.com and pull a model: ollama pull llama3.1
# No API key, no account, no spend. Needs a decent laptop and runs slower.
# Local Ollama OpenAI-compatible endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Placeholder key. Ollama ignores the value but the OpenAI SDK needs it set.
OLLAMA_API_KEY=ollama
# Local model id used for narrative enrichment.
OLLAMA_MODEL=llama3.1
# Per-request timeout for the local LLM, in seconds.
LLM_TIMEOUT_SECONDS=120
# Version tag stored with every enrichment row.
PROMPT_VERSION=v1
# Incidents grouped per enrichment work unit.
ENRICHMENT_BATCH_SIZE=20
# Minimum fraction of narrated incidents that must be classified.
MIN_ENRICHMENT_COVERAGE=0.90

# --- Airflow ---
# Generate a Fernet key:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank for a quick local demo (Airflow uses a per-process key with a warning).
AIRFLOW_FERNET_KEY=
# Flask webserver secret key. Change it for any shared host.
AIRFLOW_SECRET_KEY=changeme
# Initial Airflow UI username (created by airflow-init).
_AIRFLOW_WWW_USER_USERNAME=admin
# Initial Airflow UI password. Change it for any shared host.
_AIRFLOW_WWW_USER_PASSWORD=admin
